# Namecheap API credentials
# Get these from: Namecheap Dashboard > Profile > Tools > Namecheap API Access
NAMECHEAP_API_USER=your_api_user
NAMECHEAP_API_KEY=your_api_key
NAMECHEAP_USERNAME=your_username
NAMECHEAP_CLIENT_IP=your_whitelisted_ip

# Anthropic API key — get from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key

# Static-IP proxy for Vercel (required for Namecheap IP whitelisting)
# Get from: https://usefixie.com — free tier available
FIXIE_URL=

# Cloudflare API credentials (for Domain Provisioner)
# Token: Cloudflare Dashboard > My Profile > API Tokens > Create Token
# Permissions needed: Zone:Edit, DNS:Edit, Bot Management:Edit
# Account ID: Cloudflare Dashboard > right sidebar on any domain
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# Password gate
APP_PASSWORD=your_app_password
SESSION_SECRET=your_random_secret_string
